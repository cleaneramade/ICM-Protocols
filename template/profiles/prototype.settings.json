{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_plutus": { "profile": "prototype", "board": "Brain/00_system/APPROVAL_POLICY.md", "generated-by": "/plutus" },
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm ci)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npx prisma *)",
      "Bash(npx next *)",
      "Bash(npx tsc*)",
      "Bash(npx eslint*)",
      "Bash(npx shadcn@latest *)",
      "Bash(prisma *)",
      "Bash(git init)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(netstat *)",
      "Bash(taskkill //F //PID *)",
      "Bash(cloudflared *)",
      "mcp__claude_ai_Gmail__search_threads",
      "mcp__claude_ai_Gmail__get_thread",
      "mcp__claude_ai_Gmail__list_labels",
      "mcp__claude_ai_Gmail__list_drafts"
    ],
    "ask": [
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git remote add *)",
      "Bash(git remote set-url *)",
      "Bash(gh repo create *)",
      "Bash(gh repo edit *)",
      "Bash(vercel)",
      "Bash(vercel *)",
      "Bash(npx vercel)",
      "Bash(npx vercel *)",
      "Bash(npm install -g *)",
      "Bash(npm i -g *)",
      "Bash(curl)",
      "Bash(curl *)",
      "WebFetch"
    ],
    "deny": [
      "Read(*.pem)",
      "Read(id_rsa*)",
      "Read(secrets/**)",
      "Read(~/.claude/settings.json)",
      "Edit(~/.claude/settings.json)",
      "Write(~/.claude/settings.json)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.development)",
      "Edit(.env.production)",
      "Edit(.env.test)",
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.development)",
      "Write(.env.production)",
      "Write(.env.test)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(taskkill //F //IM *)",
      "Bash(gh repo delete)",
      "Bash(gh repo delete *)",
      "Bash(git config *)",
      "Bash(git -c *)",
      "Bash(npm publish)",
      "Bash(npm publish *)",
      "Bash(vercel --prod)",
      "Bash(vercel --prod *)",
      "Bash(npx vercel --prod)",
      "Bash(npx vercel --prod *)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowLocalBinding": true,
      "allowedDomains": [
        "localhost",
        "registry.npmjs.org",
        "*.npmjs.org",
        "fonts.googleapis.com",
        "fonts.gstatic.com"
      ]
    }
  }
}
